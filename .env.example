WORKSPACE_PATH=../www
SSH_KEY_PATH=~/.ssh/id_rsa

TIMEZONE=Asia/Shanghai
PHP_VERSION=7.3
# 留空 = build 時自動安裝當前 Active LTS（NodeSource setup_lts.x）；
# 若要鎖版本，填入 major 號碼，例如 NODEJS_VERSION=22
NODEJS_VERSION=

MYSQL_VERSION=5.7
MYSQL_HOST=localhost
MYSQL_PORT=3305
MYSQL_DATABASE=database
MYSQL_USER=user
MYSQL_PASSWORD=pass
MYSQL_ROOT_PASSWORD=pass

PHP8_VERSION=8.4
MYSQL8_VERSION=8.0.30
MYSQL8_PORT=3306

REDIS_PORT=6379
REDIS_CLUSTER_PORT_RANGE=7000-7005
