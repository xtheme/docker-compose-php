# The MySQL  Client configuration file.
#
# For explanations see
# http://dev.mysql.com/doc/mysql/en/server-system-variables.html

[mysql]

[mysqld]
# SQL Mode 配置说明：
# 与 Laravel 应用配置保持一致，移除 ONLY_FULL_GROUP_BY 以保持向后兼容性
# Laravel config/database.php 中的 'modes' 配置会覆盖此设置
#
# MySQL 8.0 默认包含 ONLY_FULL_GROUP_BY，但为了兼容旧代码，这里移除
# 参考：https://learnku.com/articles/53725
#
# sql-mode="STRICT_TRANS_TABLES,ONLY_FULL_GROUP_BY,ERROR_FOR_DIVISION_BY_ZERO,NO_ZERO_DATE,NO_ZERO_IN_DATE,NO_ENGINE_SUBSTITUTION"
sql-mode="STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION"
character-set-server=utf8
default-authentication-plugin=mysql_native_password
default-time-zone='+00:00'

log_error=/var/log/mysql/mysql_error.log
general_log_file=/var/log/mysql/mysql.log
general_log=1
slow_query_log=1
slow_query_log_file=/var/log/mysql/mysql_slow.log
long_query_time=2
log_queries_not_using_indexes=1

gtid_mode=on
enforce_gtid_consistency=on
binlog_format=ROW